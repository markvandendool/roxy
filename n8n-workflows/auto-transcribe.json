{
  "name": "Auto-Transcribe Recording",
  "nodes": [
    {
      "parameters": {
        "path": "/opt/roxy/content-pipeline/recordings",
        "options": {
          "fileExtension": ".mp4,.mkv"
        }
      },
      "name": "Watch for New Recording",
      "type": "n8n-nodes-base.watchFile",
      "position": [250, 300]
    },
    {
      "parameters": {
        "command": "cd /opt/roxy && source venv/bin/activate && python content-pipeline/whisperx_transcriber.py {{ $json.path }} /opt/roxy/content-pipeline/transcripts/",
        "options": {}
      },
      "name": "Run WhisperX",
      "type": "n8n-nodes-base.executeCommand",
      "position": [450, 300]
    },
    {
      "parameters": {
        "operation": "create",
        "resource": "collection",
        "collectionName": "transcripts",
        "properties": {
          "recording_path": "={{ $json.path }}",
          "transcript_path": "={{ $json.output }}",
          "timestamp": "={{ $now }}"
        }
      },
      "name": "Store in ChromaDB",
      "type": "n8n-nodes-base.chromadb",
      "position": [650, 300]
    }
  ],
  "connections": {
    "Watch for New Recording": {
      "main": [[{"node": "Run WhisperX", "type": "main", "index": 0}]]
    },
    "Run WhisperX": {
      "main": [[{"node": "Store in ChromaDB", "type": "main", "index": 0}]]
    }
  }
}
